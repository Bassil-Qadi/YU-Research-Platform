# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB (local: docker-compose up -d)
MONGODB_URI=mongodb://localhost:27017/research-platform

# NextAuth / Auth.js v5
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
# Legacy aliases (optional; AUTH_* preferred in v5)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Dev credentials fallback (development only)
DEV_AUTH_ENABLED=true
DEV_USER_EMAIL=demo@university.edu
DEV_USER_PASSWORD=demo123456

# SAML / university SSO (configure when ready)
SAML_ENABLED=false
SAML_IDP_METADATA_URL=
SAML_CLIENT_ID=
SAML_CLIENT_SECRET=
SAML_ISSUER=

# OAuth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Redis (Phase 2+ — sessions, rate limiting)
REDIS_URL=redis://localhost:6379

# File storage (Phase 3+)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Email (Phase 2+)
RESEND_API_KEY=
